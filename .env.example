# ═══════════════════════════════════════════════════════
# Housekeeping Platform — Environment Variables
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://app.kodspot.in
COOKIE_DOMAIN=kodspot.in

# ── Database (PostgreSQL) ────────────────────────────
DB_USER=housekeeping
DB_PASSWORD=<STRONG_RANDOM_PASSWORD>
DB_NAME=housekeeping
DATABASE_URL=postgresql://housekeeping:<STRONG_RANDOM_PASSWORD>@db:5432/housekeeping

# ── Auth Secrets ─────────────────────────────────────
JWT_SECRET=<RANDOM_64_CHAR_HEX>
COOKIE_SECRET=<RANDOM_64_CHAR_HEX>
ADMIN_KEY=<RANDOM_32_CHAR_HEX>

# ── Encryption (PII at rest) ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_ENCRYPTION_KEY=<RANDOM_64_CHAR_HEX>

# ── Cloudflare R2 Storage ────────────────────────────
R2_ACCOUNT_ID=<YOUR_CF_ACCOUNT_ID>
R2_ACCESS_KEY_ID=<YOUR_R2_ACCESS_KEY>
R2_SECRET_ACCESS_KEY=<YOUR_R2_SECRET_KEY>
R2_BUCKET_NAME=kodspot-housekeeping

# ── CORS (comma-separated origins) ───────────────────
CORS_ORIGINS=https://app.kodspot.in

# ── Rate Limiting (optional — sensible defaults) ─────
# RATE_LIMIT_MAX=1000
# RATE_LIMIT_WINDOW=60000
# ADMIN_RATE_LIMIT_MAX=5
# ADMIN_RATE_LIMIT_WINDOW=900000

# ── Email / SES (optional) ──────────────────────────
# SES_SMTP_HOST=
# SES_SMTP_USER=
# SES_SMTP_PASS=
# SES_FROM_EMAIL=
